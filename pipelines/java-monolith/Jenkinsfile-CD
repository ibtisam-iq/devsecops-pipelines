pipeline {
    agent any

    // Continuous Deployment

    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ibtisam-iq/BankingApp-Java-MySQL.git'
            }
        }

        stage('Kubernetes Deployment') {
            steps {
                dir ('manifest/') {
                    withKubeConfig(caCertificate: '', clusterName: 'ibtisamiq-cluster', contextName: '', credentialsId: 'k8-token', namespace: 'ibtisamiq', restrictKubeConfigAccess: false, serverUrl: 'https://952FB702C508F688D873376083B31DF5.gr7.ap-south-1.eks.amazonaws.com') {
                        sh "kubectl apply -f manifest.yaml -n ibtisamiq"
                        sh "kubectl apply -f HPA.yaml "
                        sleep 30
                        sh "kubectl get pods -n ibtisamiq"
                        sh "kubectl get service -n ibtisamiq"
                    }
                }
            }
        }
    }
}
